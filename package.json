{
  "name": "zkhelios",
  "version": "0.1.0",
  "private": true,
  "description": "zkHelios — Solana dApp with zero-knowledge proofs (monorepo)",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @zkhelios/web dev",
    "dev:dapp": "pnpm --filter @zkhelios/dapp dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "turbo": "^2.0.14"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "packageManager": "pnpm@9.15.9"
}
