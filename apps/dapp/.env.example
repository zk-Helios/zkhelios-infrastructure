# Session secret for iron-session (MUST be >= 32 chars in production)
SESSION_SECRET=

# Solana RPC endpoints (Helius / Triton / QuickNode recommended for mainnet)
NEXT_PUBLIC_RPC_URL_MAINNET=
NEXT_PUBLIC_RPC_URL_DEVNET=

# zkHelios Anchor program id (defaults to a placeholder until deployed in Session 6)
NEXT_PUBLIC_PROGRAM_ID=

# Backend API base URL (Sessions 7+)
NEXT_PUBLIC_API_URL=

# --- Production polish (optional; left unset = disabled) ---
# Analytics (Plausible/PostHog) and error tracking (Sentry) are env-gated and
# off until you provide keys. See Session 5 notes in the root README.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_SENTRY_DSN=
